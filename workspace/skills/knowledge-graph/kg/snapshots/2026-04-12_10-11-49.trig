        openclaw:hasDescription "Skill Manager workspace" ;
        openclaw:hasName "skill-manager" .

    kg:workspace-workspace-manager a openclaw:Workspace ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Workspace Manager workspace" ;
        openclaw:hasName "workspace-manager" .

    kg:channel-feishu a openclaw:Channel ;
