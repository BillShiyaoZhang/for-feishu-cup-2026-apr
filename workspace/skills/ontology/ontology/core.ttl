@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:   <http://purl.org/dc/terms/> .
@prefix pulsefit:  <urn:pulsefit:ontology#> .

# ── 标准词汇复用 ────────────────────────────────────────────────────────────
@prefix foaf:      <http://xmlns.com/foaf/0.1/> .
@prefix vcard:     <http://www.w3.org/2006/vcard/ns#> .
@prefix org:       <http://www.w3.org/ns/org#> .
@prefix event:     <http://purl.org/NET/c4dm/event.owl#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix time:      <http://www.w3.org/2006/time#> .

###############################################################################
# PulseFit 网红营销Knowledge Agent 核心本体
###############################################################################

<urn:pulsefit:ontology>
    a owl:Ontology ;
    owl:versionIRI     <urn:pulsefit:ontology:v1.0.0> ;
    owl:versionInfo    "1.0.0" ;
    rdfs:label         "PulseFit Influencer Marketing Knowledge Agent Ontology" ;
    rdfs:comment       """核心本体定义，覆盖网红合作全流程5幕所有场景：
1. 基础通用层：人员、组织、地址、事件、文档
2. 营销核心层：网红、产品、活动、合同、交付内容
3. 企业流程层：审批流、发货、付款
4. 规则知识层：SOP规则、决策偏好、匹配规则""" ;
    dcterms:creator    "PulseFit KnowAgent Team" ;
    dcterms:created    "2026-04-28"^^xsd:date .

###############################################################################
# ── 第一层：基础通用层 (覆盖全场景通用实体) ───────────────────────────────────
###############################################################################

# ── 人员 (覆盖所有Act的人员角色：员工、博主等) ───────────────────────────────
pulsefit:Person
    a owl:Class ;
    rdfs:label   "Person" ;
    rdfs:comment "通用人员实体，包含内部员工、外部网红、合作方人员等所有角色" ;
    rdfs:subClassOf foaf:Person .

pulsefit:Employee
    a owl:Class ;
    rdfs:label   "Employee" ;
    rdfs:comment "内部员工：实习生、Mentor、同事、管理员等" ;
    rdfs:subClassOf pulsefit:Person .

pulsefit:Influencer
    a owl:Class ;
    rdfs:label   "Influencer" ;
    rdfs:comment "外部网红/博主/KOL" ;
    rdfs:subClassOf pulsefit:Person .

# ── 组织与角色 ────────────────────────────────────────────────────────────
pulsefit:Role
    a owl:Class ;
    rdfs:label   "Role" ;
    rdfs:comment "人员角色：实习生、Mentor、物流、PM、审批人等" ;
    rdfs:subClassOf org:Role .

pulsefit:Organization
    a owl:Class ;
    rdfs:label   "Organization" ;
    rdfs:comment "组织实体：公司、部门、团队等" ;
    rdfs:subClassOf org:Organization .

# ── 地址与联系方式 ─────────────────────────────────────────────────────────
pulsefit:Address
    a owl:Class ;
    rdfs:label   "Address" ;
    rdfs:comment "联系地址/收件地址" ;
    rdfs:subClassOf vcard:Address .

pulsefit:ContactInfo
    a owl:Class ;
    rdfs:label   "ContactInfo" ;
    rdfs:comment "联系方式：邮箱、电话、社交账号主页等" ;
    rdfs:subClassOf vcard:Contact .

# ── 事件 (覆盖全流程所有事件) ──────────────────────────────────────────────
pulsefit:BusinessEvent
    a owl:Class ;
    rdfs:label   "BusinessEvent" ;
    rdfs:comment "业务事件：入职、Sourcing、审批、发货、付款、内容发布等所有流程事件" ;
    rdfs:subClassOf event:Event .

# 事件类型受控词汇
pulsefit:EventTypeValue
    a rdfs:Class ;
    rdfs:label   "EventTypeValue" ;
    owl:oneOf   ( "onboarding" "sourcing" "contract_sign" "approval_submit" "approval_pass" "approval_reject" 
                  "shipment_create" "shipment_send" "shipment_receive" "payment_apply" "payment_pay" 
                  "content_publish" "sop_update" "feedback" ) .

# ── 文档 (覆盖所有文档类实体) ───────────────────────────────────────────────
pulsefit:Document
    a owl:Class ;
    rdfs:label   "Document" ;
    rdfs:comment "通用文档实体：SOP、合同模板、审批表模板、合同PDF、发票等" .

pulsefit:SOPDocument
    a owl:Class ;
    rdfs:label   "SOPDocument" ;
    rdfs:comment "流程标准操作手册文档" ;
    rdfs:subClassOf pulsefit:Document .

pulsefit:TemplateDocument
    a owl:Class ;
    rdfs:label   "TemplateDocument" ;
    rdfs:comment "模板文档：合同模板、审批表模板等" ;
    rdfs:subClassOf pulsefit:Document .

pulsefit:ContractDocument
    a owl:Class ;
    rdfs:label   "ContractDocument" ;
    rdfs:comment "正式签署的合同文档" ;
    rdfs:subClassOf pulsefit:Document .

pulsefit:InvoiceDocument
    a owl:Class ;
    rdfs:label   "InvoiceDocument" ;
    rdfs:comment "发票/账单文档" ;
    rdfs:subClassOf pulsefit:Document .

###############################################################################
# ── 第二层：网红营销核心层 (覆盖Act1-3+Act5核心业务) ─────────────────────────
###############################################################################

# ── 产品 ───────────────────────────────────────────────────────────────────
pulsefit:Product
    a owl:Class ;
    rdfs:label   "Product" ;
    rdfs:comment "产品实体：PulseRope Pro等公司产品" .

# ── 营销活动 ───────────────────────────────────────────────────────────────
pulsefit:Campaign
    a owl:Class ;
    rdfs:label   "Campaign" ;
    rdfs:comment "营销活动：每个网红合作所属的活动项目" .

# ── 合作合同 ───────────────────────────────────────────────────────────────
pulsefit:Contract
    a owl:Class ;
    rdfs:label   "Contract" ;
    rdfs:comment "合作合同：网红合作的正式合同信息" .

# ── 交付内容 ───────────────────────────────────────────────────────────────
pulsefit:ContentDeliverable
    a owl:Class ;
    rdfs:label   "ContentDeliverable" ;
    rdfs:comment "网红交付内容：Reel、Story、Post等" .

###############################################################################
# ── 第三层：企业流程层 (覆盖Act4-5+全流程审批) ──────────────────────────────
###############################################################################

# ── 审批流 ─────────────────────────────────────────────────────────────────
pulsefit:ApprovalFlow
    a owl:Class ;
    rdfs:label   "ApprovalFlow" ;
    rdfs:comment "审批流：合同审批、发货审批、付款审批等所有审批流程" .

pulsefit:ApprovalRecord
    a owl:Class ;
    rdfs:label   "ApprovalRecord" ;
    rdfs:comment "审批记录：每一次审批操作的记录" .

# ── 发货/物流 ──────────────────────────────────────────────────────────────
pulsefit:ShipmentOrder
    a owl:Class ;
    rdfs:label   "ShipmentOrder" ;
    rdfs:comment "发货申请单" .

pulsefit:LogisticsRecord
    a owl:Class ;
    rdfs:label   "LogisticsRecord" ;
    rdfs:comment "物流记录：发货后的物流信息" .

# ── 付款/财务 ──────────────────────────────────────────────────────────────
pulsefit:PaymentOrder
    a owl:Class ;
    rdfs:label   "PaymentOrder" ;
    rdfs:comment "付款申请单" .

pulsefit:TaxCert
    a owl:Class ;
    rdfs:label   "TaxCert" ;
    rdfs:comment "税务资质文件：W-9等" .

###############################################################################
# ── 第四层：规则知识层 (覆盖所有Act的智能决策规则) ───────────────────────────
###############################################################################

pulsefit:BusinessRule
    a owl:Class ;
    rdfs:label   "BusinessRule" ;
    rdfs:comment "通用业务规则实体" .

pulsefit:SOPRule
    a owl:Class ;
    rdfs:label   "SOPRule" ;
    rdfs:comment "SOP流程规则：从SOP文档中提取的可执行规则" ;
    rdfs:subClassOf pulsefit:BusinessRule .

pulsefit:DecisionPreference
    a owl:Class ;
    rdfs:label   "DecisionPreference" ;
    rdfs:comment "决策偏好：Mentor/团队的隐性决策规则、偏好" ;
    rdfs:subClassOf pulsefit:BusinessRule .

pulsefit:MatchingRule
    a owl:Class ;
    rdfs:label   "MatchingRule" ;
    rdfs:comment "匹配规则：博主-产品匹配、报价计算规则等" ;
    rdfs:subClassOf pulsefit:BusinessRule .

###############################################################################
# ── 全局通用属性 ───────────────────────────────────────────────────────────
###############################################################################

pulsefit:hasName
    a owl:DatatypeProperty ;
    rdfs:label   "hasName" ;
    rdfs:comment "实体名称" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   xsd:string .

pulsefit:hasDescription
    a owl:DatatypeProperty ;
    rdfs:label   "hasDescription" ;
    rdfs:comment "实体描述" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   xsd:string .

pulsefit:createdAt
    a owl:DatatypeProperty ;
    rdfs:label   "createdAt" ;
    rdfs:comment "创建时间" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   xsd:dateTime .

pulsefit:updatedAt
    a owl:DatatypeProperty ;
    rdfs:label   "updatedAt" ;
    rdfs:comment "更新时间" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   xsd:dateTime .

pulsefit:relatedTo
    a owl:ObjectProperty ;
    a owl:SymmetricProperty ;
    rdfs:label   "relatedTo" ;
    rdfs:comment "实体间关联关系" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   owl:Thing .

###############################################################################
# ── 基础层属性 ─────────────────────────────────────────────────────────────
###############################################################################

# 人员属性
pulsefit:hasRole
    a owl:ObjectProperty ;
    rdfs:label   "hasRole" ;
    rdfs:comment "人员所属角色" ;
    rdfs:domain  pulsefit:Person ;
    rdfs:range   pulsefit:Role .

pulsefit:belongsTo
    a owl:ObjectProperty ;
    rdfs:label   "belongsTo" ;
    rdfs:comment "人员/实体所属组织/部门" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   pulsefit:Organization .

pulsefit:hasAddress
    a owl:ObjectProperty ;
    rdfs:label   "hasAddress" ;
    rdfs:comment "人员/实体拥有的地址" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   pulsefit:Address .

pulsefit:hasContact
    a owl:ObjectProperty ;
    rdfs:label   "hasContact" ;
    rdfs:comment "人员拥有的联系方式" ;
    rdfs:domain  pulsefit:Person ;
    rdfs:range   pulsefit:ContactInfo .

# 事件属性
pulsefit:eventType
    a owl:DatatypeProperty ;
    rdfs:label   "eventType" ;
    rdfs:comment "事件类型" ;
    rdfs:domain  pulsefit:BusinessEvent ;
    rdfs:range   xsd:string .

pulsefit:hasParticipant
    a owl:ObjectProperty ;
    rdfs:label   "hasParticipant" ;
    rdfs:comment "事件参与人" ;
    rdfs:domain  pulsefit:BusinessEvent ;
    rdfs:range   pulsefit:Person .

pulsefit:hasEventTime
    a owl:DatatypeProperty ;
    rdfs:label   "hasEventTime" ;
    rdfs:comment "事件发生时间" ;
    rdfs:domain  pulsefit:BusinessEvent ;
    rdfs:range   xsd:dateTime .

###############################################################################
# ── 营销核心层属性 ─────────────────────────────────────────────────────────
###############################################################################

# 网红属性
pulsefit:followerCount
    a owl:DatatypeProperty ;
    rdfs:label   "followerCount" ;
    rdfs:comment "粉丝量" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   xsd:integer .

pulsefit:contentType
    a owl:DatatypeProperty ;
    rdfs:label   "contentType" ;
    rdfs:comment "内容类型：跑步、居家训练、健身等" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   xsd:string .

pulsefit:averageViews
    a owl:DatatypeProperty ;
    rdfs:label   "averageViews" ;
    rdfs:comment "近30天平均播放量" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   xsd:integer .

pulsefit:engagementRate
    a owl:DatatypeProperty ;
    rdfs:label   "engagementRate" ;
    rdfs:comment "互动率" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   xsd:float .

pulsefit:platform
    a owl:DatatypeProperty ;
    rdfs:label   "platform" ;
    rdfs:comment "平台：Instagram、TikTok、YouTube等" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   xsd:string .

# 产品属性
pulsefit:productModel
    a owl:DatatypeProperty ;
    rdfs:label   "productModel" ;
    rdfs:comment "产品型号" ;
    rdfs:domain  pulsefit:Product ;
    rdfs:range   xsd:string .

pulsefit:productColor
    a owl:DatatypeProperty ;
    rdfs:label   "productColor" ;
    rdfs:comment "产品颜色" ;
    rdfs:domain  pulsefit:Product ;
    rdfs:range   xsd:string .

pulsefit:productSize
    a owl:DatatypeProperty ;
    rdfs:label   "productSize" ;
    rdfs:comment "产品尺寸" ;
    rdfs:domain  pulsefit:Product ;
    rdfs:range   xsd:string .

pulsefit:applicableScenario
    a owl:DatatypeProperty ;
    rdfs:label   "applicableScenario" ;
    rdfs:comment "适用场景：家用 cardio、HIIT等" ;
    rdfs:domain  pulsefit:Product ;
    rdfs:range   xsd:string .

# 活动属性
pulsefit:campaignBudget
    a owl:DatatypeProperty ;
    rdfs:label   "campaignBudget" ;
    rdfs:comment "活动预算" ;
    rdfs:domain  pulsefit:Campaign ;
    rdfs:range   xsd:float .

pulsefit:campaignStartDate
    a owl:DatatypeProperty ;
    rdfs:label   "campaignStartDate" ;
    rdfs:comment "活动开始时间" ;
    rdfs:domain  pulsefit:Campaign ;
    rdfs:range   xsd:date .

pulsefit:campaignEndDate
    a owl:DatatypeProperty ;
    rdfs:label   "campaignEndDate" ;
    rdfs:comment "活动结束时间" ;
    rdfs:domain  pulsefit:Campaign ;
    rdfs:range   xsd:date .

# 合同属性
pulsefit:contractAmount
    a owl:DatatypeProperty ;
    rdfs:label   "contractAmount" ;
    rdfs:comment "合同金额（美元）" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   xsd:float .

pulsefit:contractSignDate
    a owl:DatatypeProperty ;
    rdfs:label   "contractSignDate" ;
    rdfs:comment "合同签署日期" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   xsd:date .

pulsefit:contractExpireDate
    a owl:DatatypeProperty ;
    rdfs:label   "contractExpireDate" ;
    rdfs:comment "合同到期日期" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   xsd:date .

pulsefit:contractStatus
    a owl:DatatypeProperty ;
    rdfs:label   "contractStatus" ;
    rdfs:comment "合同状态：draft、signed、expired等" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   xsd:string .

# 交付内容属性
pulsefit:contentType
    a owl:DatatypeProperty ;
    rdfs:label   "contentType" ;
    rdfs:comment "内容类型：Reel、Story、Post等" ;
    rdfs:domain  pulsefit:ContentDeliverable ;
    rdfs:range   xsd:string .

pulsefit:publishDate
    a owl:DatatypeProperty ;
    rdfs:label   "publishDate" ;
    rdfs:comment "发布日期" ;
    rdfs:domain  pulsefit:ContentDeliverable ;
    rdfs:range   xsd:date .

pulsefit:contentUrl
    a owl:DatatypeProperty ;
    rdfs:label   "contentUrl" ;
    rdfs:comment "内容链接" ;
    rdfs:domain  pulsefit:ContentDeliverable ;
    rdfs:range   xsd:string .

pulsefit:contentViews
    a owl:DatatypeProperty ;
    rdfs:label   "contentViews" ;
    rdfs:comment "播放量/浏览量" ;
    rdfs:domain  pulsefit:ContentDeliverable ;
    rdfs:range   xsd:integer .

# 核心关系
pulsefit:hasContractWith
    a owl:ObjectProperty ;
    rdfs:label   "hasContractWith" ;
    rdfs:comment "网红与公司签有合同" ;
    rdfs:domain  pulsefit:Influencer ;
    rdfs:range   pulsefit:Contract .

pulsefit:belongsToCampaign
    a owl:ObjectProperty ;
    rdfs:label   "belongsToCampaign" ;
    rdfs:comment "合同/交付内容所属活动" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   pulsefit:Campaign .

pulsefit:usesProduct
    a owl:ObjectProperty ;
    rdfs:label   "usesProduct" ;
    rdfs:comment "合同/活动使用的产品" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   pulsefit:Product .

pulsefit:hasDeliverable
    a owl:ObjectProperty ;
    rdfs:label   "hasDeliverable" ;
    rdfs:comment "合同约定的交付内容" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   pulsefit:ContentDeliverable .

###############################################################################
# ── 企业流程层属性 ─────────────────────────────────────────────────────────
###############################################################################

# 审批属性
pulsefit:approvalStatus
    a owl:DatatypeProperty ;
    rdfs:label   "approvalStatus" ;
    rdfs:comment "审批状态：pending、pass、reject" ;
    rdfs:domain  pulsefit:ApprovalFlow ;
    rdfs:range   xsd:string .

pulsefit:approver
    a owl:ObjectProperty ;
    rdfs:label   "approver" ;
    rdfs:comment "审批人" ;
    rdfs:domain  pulsefit:ApprovalRecord ;
    rdfs:range   pulsefit:Employee .

pulsefit:approvalComment
    a owl:DatatypeProperty ;
    rdfs:label   "approvalComment" ;
    rdfs:comment "审批意见" ;
    rdfs:domain  pulsefit:ApprovalRecord ;
    rdfs:range   xsd:string .

# 发货属性
pulsefit:shipmentStatus
    a owl:DatatypeProperty ;
    rdfs:label   "shipmentStatus" ;
    rdfs:comment "发货状态：pending、shipped、delivered" ;
    rdfs:domain  pulsefit:ShipmentOrder ;
    rdfs:range   xsd:string .

pulsefit:trackingNumber
    a owl:DatatypeProperty ;
    rdfs:label   "trackingNumber" ;
    rdfs:comment "物流单号" ;
    rdfs:domain  pulsefit:LogisticsRecord ;
    rdfs:range   xsd:string .

pulsefit:shipDate
    a owl:DatatypeProperty ;
    rdfs:label   "shipDate" ;
    rdfs:comment "发货日期" ;
    rdfs:domain  pulsefit:ShipmentOrder ;
    rdfs:range   xsd:date .

# 付款属性
pulsefit:paymentAmount
    a owl:DatatypeProperty ;
    rdfs:label   "paymentAmount" ;
    rdfs:comment "付款金额" ;
    rdfs:domain  pulsefit:PaymentOrder ;
    rdfs:range   xsd:float .

pulsefit:paymentStatus
    a owl:DatatypeProperty ;
    rdfs:label   "paymentStatus" ;
    rdfs:comment "付款状态：pending、paid、failed" ;
    rdfs:domain  pulsefit:PaymentOrder ;
    rdfs:range   xsd:string .

pulsefit:invoiceNumber
    a owl:DatatypeProperty ;
    rdfs:label   "invoiceNumber" ;
    rdfs:comment "发票号" ;
    rdfs:domain  pulsefit:InvoiceDocument ;
    rdfs:range   xsd:string .

# 流程关系
pulsefit:hasApproval
    a owl:ObjectProperty ;
    rdfs:label   "hasApproval" ;
    rdfs:comment "合同/发货单/付款单关联的审批流" ;
    rdfs:domain  owl:Thing ;
    rdfs:range   pulsefit:ApprovalFlow .

pulsefit:hasShipment
    a owl:ObjectProperty ;
    rdfs:label   "hasShipment" ;
    rdfs:comment "合同关联的发货单" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   pulsefit:ShipmentOrder .

pulsefit:hasPayment
    a owl:ObjectProperty ;
    rdfs:label   "hasPayment" ;
    rdfs:comment "合同关联的付款单" ;
    rdfs:domain  pulsefit:Contract ;
    rdfs:range   pulsefit:PaymentOrder .

###############################################################################
# ── 规则知识层属性 ─────────────────────────────────────────────────────────
###############################################################################

pulsefit:rulePriority
    a owl:DatatypeProperty ;
    rdfs:label   "rulePriority" ;
    rdfs:comment "规则优先级：1最高，数字越小优先级越高" ;
    rdfs:domain  pulsefit:BusinessRule ;
    rdfs:range   xsd:integer .

pulsefit:ruleCondition
    a owl:DatatypeProperty ;
    rdfs:label   "ruleCondition" ;
    rdfs:comment "规则触发条件（自然语言描述）" ;
    rdfs:domain  pulsefit:BusinessRule ;
    rdfs:range   xsd:string .

pulsefit:ruleAction
    a owl:DatatypeProperty ;
    rdfs:label   "ruleAction" ;
    rdfs:comment "规则执行动作（自然语言描述）" ;
    rdfs:domain  pulsefit:BusinessRule ;
    rdfs:range   xsd:string .

pulsefit:appliesTo
    a owl:ObjectProperty ;
    rdfs:label   "appliesTo" ;
    rdfs:comment "规则适用的场景/实体类型" ;
    rdfs:domain  pulsefit:BusinessRule ;
    rdfs:range   owl:Class .

pulsefit:createdBy
    a owl:ObjectProperty ;
    rdfs:label   "createdBy" ;
    rdfs:comment "规则创建人（Mentor等）" ;
    rdfs:domain  pulsefit:DecisionPreference ;
    rdfs:range   pulsefit:Employee .
