        ns1:productModel "Mirror One Plus" ;
        ns1:screenSize "43 inch 4K" ;
        openclaw:updatedAt "2026-04-28T09:26:21+00:00"^^xsd:dateTime .

    kg:concept-product-pulseband-flex a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:25:08+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "智能运动手环，支持心率监测、睡眠跟踪、运动记录、消息提醒功能，适合日常佩戴、多场景运动监测" ;
        openclaw:hasName "PulseBand Flex" ;
        ns1:applicableScenario "日常佩戴, 跑步, 健身, 睡眠监测" ;
        ns1:availableColors "Black, White, Mint, Pink" ;
        ns1:availableSizes "S, M, L" ;
        ns1:priceUSD 8.999e+01 ;
        ns1:productCategory "Wearable Device" ;
        ns1:productModel "PulseBand Flex" ;
        openclaw:updatedAt "2026-04-28T09:25:08+00:00"^^xsd:dateTime .

    kg:concept-product-pulsedumbbell-a2 a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:25:55+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "智能可调节哑铃，支持重量一键调节、动作识别、计数、卡路里计算，适配APP课程，适合家庭力量训练" ;
        openclaw:hasName "PulseDumbbell A2" ;
        ns1:adjustableWeightRange "2-20kg" ;
        ns1:applicableScenario "家庭力量训练, 哑铃课程, 肌力训练" ;
        ns1:availableColors "Black, Gray" ;
        ns1:priceUSD 2.9999e+02 ;
        ns1:productCategory "Strength Equipment" ;
        ns1:productModel "PulseDumbbell A2" ;
        openclaw:updatedAt "2026-04-28T09:25:55+00:00"^^xsd:dateTime .

    kg:concept-product-pulserope-pro a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:24:37+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "智能跳绳产品，内置计数、卡路里计算、APP数据同步功能，适合居家HIIT、 cardio训练场景" ;
        openclaw:hasName "PulseRope Pro" ;
        ns1:applicableScenario "家用 cardio, HIIT, 居家训练, 跳绳爱好者" ;
        ns1:availableColors "Black, Sand, Charcoal" ;
        ns1:availableSizes "One size, M, L" ;
        ns1:priceUSD 4.999e+01 ;
        ns1:productCategory "Fitness Equipment" ;
        ns1:productModel "PulseRope Pro" ;
        openclaw:updatedAt "2026-04-28T09:24:37+00:00"^^xsd:dateTime .

    kg:concept-rule-influencer-product-match a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:30:01+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "从历史项目复盘中提取的博主内容类型与产品的匹配规则，用于Sourcing阶段的产品推荐" ;
        openclaw:hasName "博主-产品匹配规则" ;
        ns1:appliesTo "Influencer Sourcing" ;
        ns1:createdAt "2026-03-20^^xsd:date" ;
        ns1:createdBy kg:person-hannah-brooks ;
        ns1:ruleAction "匹配规则：1.跑步/居家HIIT/跳绳内容→推荐PulseRope Pro；2.日常穿戴/步数/睡眠监测内容→推荐PulseBand Flex；3.力量训练/哑铃内容→推荐PulseDumbbell A2；4.家庭健身/全品类课程内容→推荐Mirror One Plus" ;
        ns1:ruleCondition "Sourcing阶段新增博主时触发" ;
        ns1:rulePriority 2 ;
        openclaw:updatedAt "2026-04-28T09:30:01+00:00"^^xsd:dateTime .

    kg:concept-rule-payment-verification a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:29:24+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Daniel 2026-04-09在群聊中明确的付款前必须全Y校验规则，有任何一项N都不能提交审批" ;
        openclaw:hasName "Daniel 付款前多源校验规则" ;
        ns1:appliesTo "Payment Order" ;
        ns1:createdAt "2026-04-09^^xsd:date" ;
        ns1:createdBy kg:person-daniel-tobias ;
        ns1:ruleAction "检查：1.交付物全部上线（Reel/Story数量符合合同）；2.Bio Link已验证；3.Hashtag已验证（#PulseFit, #ad）；4.Paid Usage已设置；5.效果数据已回写到数据库；有任何一项N都不能提交审批" ;
        ns1:ruleCondition "付款申请提交时自动触发" ;
        ns1:rulePriority 1 ;
        openclaw:updatedAt "2026-04-28T09:29:24+00:00"^^xsd:dateTime .

    kg:concept-rule-shipment-check a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:28:53+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Daniel 2026-03-15在群聊中明确的发货前必须检查的四项规则，不符合不能提交审批" ;
        openclaw:hasName "Daniel 发货前四件自查规则" ;
        ns1:appliesTo "Shipment Order" ;
        ns1:createdAt "2026-03-15^^xsd:date" ;
        ns1:createdBy kg:person-daniel-tobias ;
        ns1:ruleAction "检查：1.地址完整（street + city + state + ZIP 四件套）；2.产品型号、颜色、尺码和合同一致；3.Promised Delivery Date 已填；4.POC 和 Manage by 已填对人；全部符合才允许提交审批" ;
        ns1:ruleCondition "发货申请提交时自动触发" ;
        ns1:rulePriority 1 ;
        openclaw:updatedAt "2026-04-28T09:28:53+00:00"^^xsd:dateTime .
}

