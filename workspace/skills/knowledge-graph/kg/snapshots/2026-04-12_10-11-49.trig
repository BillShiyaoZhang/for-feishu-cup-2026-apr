        openclaw:hasDescription "Routes feishu messages from ou_949a455ce41a4a92cb574a9d4e5f2867 to agent main." ;
        openclaw:hasName "main→feishu/main" ;
        openclaw:matchesChannel kg:channel-feishu ;
        openclaw:matchesPeerId "ou_949a455ce41a4a92cb574a9d4e5f2867" ;
        openclaw:routesToAgent kg:agent-main .

    kg:plugin-feishu a openclaw:Plugin ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Feishu/Lark plugin for OpenClaw — handles channels, Bitable, Drive, Wiki APIs. Version 2026.3.13." ;
        openclaw:hasName "feishu" ;
