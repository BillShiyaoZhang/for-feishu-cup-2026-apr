<urn:openclaw:graph:agents> {
    kg:agent-search a openclaw:Agent ;
        openclaw:agentId "search" ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Web search agent using MiniMax search tool." ;
        openclaw:hasName "Search Agent" ;
        openclaw:hasWorkspace kg:workspace-search ;
        openclaw:isDefaultAgent false ;
        openclaw:usesProvider kg:provider-minimax-portal .

    kg:agent-skill-manager a openclaw:Agent ;
        openclaw:agentId "skill-manager" ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Manages skill installation, updates, and ClawhHub integration." ;
        openclaw:hasName "Skill Manager" ;
        openclaw:hasWorkspace kg:workspace-skill-manager ;
        openclaw:isDefaultAgent false ;
        openclaw:usesProvider kg:provider-minimax-portal ;
        openclaw:usesSkill kg:skill-clawhub-install,
            kg:skill-clawhub-publish,
            kg:skill-clawhub-search,
            kg:skill-clawhub-update,
            kg:skill-skill-inventory,
            kg:skill-skill-lifecycle .

    kg:agent-workspace-manager a openclaw:Agent ;
        openclaw:agentId "workspace-manager" ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Manages workspace files, AGENTS.md, SOUL.md, and workspace hygiene." ;
        openclaw:hasName "Workspace Manager" ;
        openclaw:hasWorkspace kg:workspace-workspace-manager ;
        openclaw:isDefaultAgent false ;
        openclaw:usesProvider kg:provider-minimax-portal .

    kg:agent-main a openclaw:Agent ;
        openclaw:agentId "main" ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Bill's primary agent — coordinates all subagents, runs calendar, KG, ontology, and system management." ;
        openclaw:hasName "Claw" ;
        openclaw:hasWorkspace kg:workspace-main ;
        openclaw:isDefaultAgent true ;
        openclaw:usesProvider kg:provider-minimax-portal ;
        openclaw:usesSkill kg:skill-agent-registry,
            kg:skill-code,
            kg:skill-knowledge-graph,
            kg:skill-microsoft-graph-calendar,
            kg:skill-ontology,
            kg:skill-spawn-agent,
            kg:skill-understand-image,
            kg:skill-weather,
            kg:skill-web-search .
}

