<urn:openclaw:graph:concepts> {
    kg:concept-hub-and-spoke a openclaw:Concept ;
        openclaw:createdAt "2026-02-28T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Multi-agent pattern: central Feishu Bitable hub with specialized edge agents (business-manager, dispatch, field-execution)." ;
        openclaw:hasName "Hub-and-Spoke Architecture" .

    kg:concept-ontology-debug a openclaw:Concept ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "SHACL validation issues with xsd:anyURI for https URLs - use xsd:string instead. Prefixed names cannot contain '/' - use full URIs." ;
        openclaw:hasName "Ontology Skill Debugging" .
}

