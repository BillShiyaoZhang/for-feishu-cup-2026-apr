{
  "version": "1.0.0",
  "description": "KG partition configuration for memory system migration",
  "partitions": {
    "core": {
      "file": "graph.trig",
      "alwaysLoad": true,
      "description": "Core KG: agents, skills, people, locations, concepts"
    },
    "events": {
      "pattern": "graph-events-YYYY-QN.trig",
      "description": "Event KG: episodic/event memories partitioned by quarter",
      "quarters": [
        "2026-Q1",
        "2026-Q2",
        "2026-Q3",
        "2026-Q4",
        "2027-Q1"
      ]
    }
  },
  "namespaces": {
    "openclaw": "urn:openclaw:ontology#",
    "kg": "urn:openclaw:kg:",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "event": "http://purl.org/NET/c4dm/event.owl#"
  },
  "eventTypes": [
    "travel",
    "meeting",
    "social",
    "task",
    "system",
    "daily"
  ]
}
