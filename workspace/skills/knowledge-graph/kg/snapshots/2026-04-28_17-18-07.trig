        openclaw:updatedAt "2026-04-28T08:43:43+00:00"^^xsd:dateTime .

    kg:concept-pulserope-pro a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T08:43:13+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "智能跳绳产品，适合居家HIIT、 cardio训练场景" ;
        openclaw:hasName "PulseRope Pro" ;
        ns1:applicableScenario "家用 cardio, HIIT, 居家训练" ;
        ns1:availableColors "Black, Sand, Charcoal" ;
        ns1:availableSizes "One size, M, L" ;
        ns1:productModel "PulseRope Pro" ;
        openclaw:updatedAt "2026-04-28T08:43:13+00:00"^^xsd:dateTime .
}

