<urn:openclaw:graph:agents> {
    kg:agent-business-manager a openclaw:Agent ;
        openclaw:agentId "business-manager" ;
        openclaw:createdAt "2026-02-28T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Business manager agent for order processing. Parses unstructured text, calls Feishu Bitable API to write main orders and transport records." ;
        openclaw:hasName "business-manager" .

    kg:agent-claw a openclaw:Agent ;
        openclaw:agentId "claw" ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Bill's primary AI assistant. Coordinates subagents, manages schedules via Microsoft Graph Calendar, handles image understanding, weather queries, and web search. Embodies the Claw persona with a helpful, efficient, to-the-point vibe. Can directly handle calendar/weather/images, or delegate to subagents like skill-manager, workspace-manager, memory-manager, and search." ;
        openclaw:hasName "Claw" ;
        openclaw:isDefaultAgent true ;
        openclaw:updatedAt "2026-04-01T11:50:00+00:00"^^xsd:dateTime ;
        openclaw:usesSkill kg:skill-agent-registry,
            kg:skill-create-agent,
            kg:skill-knowledge-graph,
            kg:skill-microsoft-graph-calendar,
            kg:skill-ontology,
            kg:skill-spawn-agent,
            kg:skill-understand-image,
            kg:skill-weather,
            kg:skill-web-search .

    kg:agent-dispatch a openclaw:Agent ;
        openclaw:agentId "dispatch" ;
        openclaw:createdAt "2026-02-28T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Dispatch agent. Monitors Bitable changes, assigns tasks to drivers/workers, follows up, and generates closure reports." ;
        openclaw:hasName "dispatch" .

    kg:agent-field-execution a openclaw:Agent ;
        openclaw:agentId "field-execution" ;
        openclaw:createdAt "2026-02-28T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Field execution agent. Understands colloquial expressions (e.g., 'finished unloading'), handles photo uploads, updates status." ;
        openclaw:hasName "field-execution" .

    kg:agent-mas-business-automation a openclaw:Agent ;
        openclaw:agentId "mas-business-automation" ;
        openclaw:createdAt "2026-02-28T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Multi-agent system orchestrator. Hub-and-spoke architecture with Feishu Bitable as central hub and specialized agents at the edges." ;
        openclaw:hasName "mas-business-automation" .
}

