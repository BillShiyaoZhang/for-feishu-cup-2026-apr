    kg:concept-product-mirror-one-plus a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T09:26:21+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "智能健身镜，内置AI动作识别、实时纠正、上千节课程、多人在线对抗功能，适合家庭全场景健身" ;
        openclaw:hasName "Mirror One Plus" ;
        ns1:applicableScenario "家庭全场景健身, 瑜伽, 有氧操, 力量训练, 亲子运动" ;
        ns1:availableColors "Black, White" ;
        ns1:priceUSD 1.49999e+03 ;
