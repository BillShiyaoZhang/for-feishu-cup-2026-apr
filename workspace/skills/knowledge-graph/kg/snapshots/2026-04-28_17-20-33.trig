@prefix kg: <urn:openclaw:kg:> .
@prefix ns1: <urn:openclaw:ontology#pulsefit:> .
@prefix openclaw: <urn:openclaw:ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:openclaw:graph:concepts> {
    kg:concept-rule-mentor-shipment-check a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T08:44:30+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Mentor Daniel 2026-03-15在群聊中明确的发货前必须检查的四项规则" ;
        openclaw:hasName "Daniel 发货前四件自查规则" ;
        ns1:appliesTo "pulsefit:ShipmentOrder" ;
        ns1:createdBy kg:person-daniel-tobias ;
        ns1:ruleAction "检查：1.地址完整（street + city + state + ZIP 四件套）；2.产品型号、颜色、尺码和合同一致；3.Promised Delivery Date 已填；4.POC 和 Manage by 已填对人；全部符合才允许提交审批" ;
        ns1:ruleCondition "发货申请提交时触发" ;
        ns1:rulePriority 1 ;
        openclaw:updatedAt "2026-04-28T08:44:30+00:00"^^xsd:dateTime .

    kg:concept-rule-payment-verification a openclaw:Concept ;
        openclaw:createdAt "2026-04-28T08:48:41+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Mentor Daniel 2026-04-09在群聊中明确的付款前必须全Y校验规则" ;
        openclaw:hasName "Daniel 付款前多源校验规则" ;
        ns1:appliesTo "pulsefit:PaymentOrder" ;
        ns1:createdBy kg:person-daniel-tobias ;
        ns1:ruleAction "检查：1.交付物全部上线（Reel/Story数量符合合同）；2.Bio Link已验证；3.Hashtag已验证；4.Paid Usage已设置；5.效果数据已回写数据库；有任何一项N都不能提交审批" ;
        ns1:ruleCondition "付款申请提交时触发" ;
        ns1:rulePriority 1 ;
        openclaw:updatedAt "2026-04-28T08:48:41+00:00"^^xsd:dateTime .
}

