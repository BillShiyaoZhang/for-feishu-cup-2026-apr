@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix openclaw:  <urn:openclaw:ontology#> .
@prefix kg:        <urn:openclaw:kg:> .

###############################################################################
# Example: Full system configuration in the Knowledge Graph
#
# In the actual KG (graph.trig), each section would be in its own named graph.
# This file shows: Gateway, Agents, Channels, Bindings, Providers, Workspaces.
###############################################################################

# -- Gateway ------------------------------------------------------------------

kg:gateway-main
    a openclaw:Gateway ;
    openclaw:hasName        "Main Gateway" ;
    openclaw:hasDescription "The primary OpenClaw Gateway daemon running on this host." ;
    openclaw:bindHost       "127.0.0.1:18789" ;
    openclaw:managesChannel kg:channel-whatsapp-personal ;
    openclaw:managesChannel kg:channel-telegram-default ;
    openclaw:managesChannel kg:channel-discord-default ;
    openclaw:hostsAgent     kg:agent-main ;
    openclaw:hostsAgent     kg:agent-work ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/architecture> ;
    openclaw:createdAt      "2026-01-01T00:00:00Z"^^xsd:dateTime .

# -- Providers ----------------------------------------------------------------

kg:provider-anthropic
    a openclaw:Provider ;
    openclaw:hasName         "Anthropic Claude" ;
    openclaw:hasDescription  "Anthropic LLM provider, including Claude Sonnet and Opus." ;
    openclaw:providerName    "anthropic" ;
    openclaw:modelRef        "anthropic/claude-sonnet-4-6" ;
    openclaw:isLocalProvider false ;
    openclaw:docUrl          <https://docs.openclaw.ai/providers> .

kg:provider-ollama
    a openclaw:Provider ;
    openclaw:hasName         "Ollama (local)" ;
    openclaw:hasDescription  "Local LLM provider running models via Ollama on this machine." ;
    openclaw:providerName    "ollama" ;
    openclaw:isLocalProvider true ;
    openclaw:docUrl          <https://docs.openclaw.ai/providers> .

# -- Workspaces ---------------------------------------------------------------

kg:workspace-main
    a openclaw:Workspace ;
    openclaw:hasName        "Main Workspace" ;
    openclaw:hasDescription "Default workspace at ~/.openclaw/workspace." ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/agent-workspace> .

kg:workspace-work
    a openclaw:Workspace ;
    openclaw:hasName        "Work Workspace" ;
    openclaw:hasDescription "Work agent workspace at ~/.openclaw/workspace-work." ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/agent-workspace> .

# -- Agents -------------------------------------------------------------------

kg:agent-main
    a openclaw:Agent ;
    openclaw:hasName        "Antigravity" ;
    openclaw:hasDescription """The primary OpenClaw AI coding assistant. Handles
everyday messaging across WhatsApp and Discord.""" ;
    openclaw:agentId        "main" ;
    openclaw:isDefaultAgent true ;
    openclaw:hasWorkspace   kg:workspace-main ;
    openclaw:usesProvider   kg:provider-anthropic ;
    openclaw:usesTool       kg:tool-exec ;
    openclaw:usesTool       kg:tool-browser ;
    openclaw:usesTool       kg:tool-web-search ;
    openclaw:usesTool       kg:tool-memory-search ;
    openclaw:usesSkill      kg:skill-ontology ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/agent> ;
    openclaw:createdAt      "2026-01-01T00:00:00Z"^^xsd:dateTime .

kg:agent-work
    a openclaw:Agent ;
    openclaw:hasName        "Work Agent" ;
    openclaw:hasDescription "Dedicated agent for work tasks on Telegram with deep-work model." ;
    openclaw:agentId        "work" ;
    openclaw:isDefaultAgent false ;
    openclaw:hasWorkspace   kg:workspace-work ;
    openclaw:usesProvider   kg:provider-anthropic ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/agent> ;
    openclaw:createdAt      "2026-01-01T00:00:00Z"^^xsd:dateTime .

# -- Tools --------------------------------------------------------------------

kg:tool-exec
    a openclaw:Tool ;
    openclaw:hasName        "exec" ;
    openclaw:hasDescription "Executes shell commands and scripts on the host system." ;
    openclaw:toolGroup      "group:runtime" ;
    openclaw:isBuiltin      true ;
    openclaw:docUrl         <https://docs.openclaw.ai/tools/exec> .

kg:tool-browser
    a openclaw:Tool ;
    openclaw:hasName        "browser" ;
    openclaw:hasDescription "Opens and interacts with web pages in a headless browser." ;
    openclaw:toolGroup      "group:web" ;
    openclaw:isBuiltin      true ;
    openclaw:docUrl         <https://docs.openclaw.ai/tools/browser> .

kg:tool-web-search
    a openclaw:Tool ;
    openclaw:hasName        "web_search" ;
    openclaw:hasDescription "Searches the web and returns summarized results." ;
    openclaw:toolGroup      "group:web" ;
    openclaw:isBuiltin      true .

kg:tool-memory-search
    a openclaw:Tool ;
    openclaw:hasName        "memory_search" ;
    openclaw:hasDescription "Searches memory files using semantic search." ;
    openclaw:toolGroup      "group:memory" ;
    openclaw:isBuiltin      true ;
    openclaw:docUrl         <https://docs.openclaw.ai/concepts/memory> .

kg:tool-apply-patch
    a openclaw:Tool ;
    openclaw:hasName        "apply_patch" ;
    openclaw:hasDescription "Applies unified diff patches to files in the workspace." ;
    openclaw:toolGroup      "group:fs" ;
    openclaw:isBuiltin      true ;
    openclaw:docUrl         <https://docs.openclaw.ai/tools/apply-patch> .

# -- Channels -----------------------------------------------------------------

kg:channel-whatsapp-personal
    a openclaw:Channel ;
    openclaw:hasName        "WhatsApp Personal" ;
    openclaw:hasDescription "Personal WhatsApp account connected via Baileys QR pairing." ;
    openclaw:channelType    "whatsapp" ;
    openclaw:accountId      "personal" ;
    openclaw:isPlugin       false ;
    openclaw:docUrl         <https://docs.openclaw.ai/channels/whatsapp> .

kg:channel-telegram-default
    a openclaw:Channel ;
    openclaw:hasName        "Telegram Bot (default)" ;
    openclaw:hasDescription "Telegram bot connected via grammY and Bot API token." ;
    openclaw:channelType    "telegram" ;
    openclaw:accountId      "default" ;
    openclaw:isPlugin       false ;
    openclaw:docUrl         <https://docs.openclaw.ai/channels/telegram> .

kg:channel-discord-default
    a openclaw:Channel ;
    openclaw:hasName        "Discord Bot (default)" ;
    openclaw:hasDescription "Discord bot connected via Bot API Gateway with Message Content Intent." ;
    openclaw:channelType    "discord" ;
    openclaw:accountId      "default" ;
    openclaw:isPlugin       false ;
    openclaw:docUrl         <https://docs.openclaw.ai/channels/discord> .

# -- Bindings -----------------------------------------------------------------

kg:binding-whatsapp-to-main
    a openclaw:Binding ;
    openclaw:hasName        "WhatsApp Personal -> Main Agent" ;
    openclaw:hasDescription "Routes all WhatsApp personal account messages to the main agent." ;
    openclaw:routesToAgent  kg:agent-main ;
    openclaw:matchesChannel kg:channel-whatsapp-personal .

kg:binding-telegram-to-work
    a openclaw:Binding ;
    openclaw:hasName        "Telegram Default -> Work Agent" ;
    openclaw:hasDescription "Routes all Telegram messages to the work agent." ;
    openclaw:routesToAgent  kg:agent-work ;
    openclaw:matchesChannel kg:channel-telegram-default .

kg:binding-discord-to-main
    a openclaw:Binding ;
    openclaw:hasName        "Discord Default -> Main Agent" ;
    openclaw:hasDescription "Routes all Discord messages to the main agent." ;
    openclaw:routesToAgent  kg:agent-main ;
    openclaw:matchesChannel kg:channel-discord-default .
