        openclaw:sessionId "cron-memory-sync" .

    kg:session-cron-morning-briefing a openclaw:Session ;
        openclaw:createdAt "2026-04-01T00:00:00+00:00"^^xsd:dateTime ;
        openclaw:hasDescription "Daily at 07:00 Asia/Shanghai — summarizes calendar and sends to Bill via Feishu." ;
        openclaw:hasName "Morning Briefing Cron" ;
        openclaw:sessionId "cron-morning-briefing" .

    kg:workspace-main a openclaw:Workspace ;
