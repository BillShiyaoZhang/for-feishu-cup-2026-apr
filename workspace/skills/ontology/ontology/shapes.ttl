@prefix sh:        <http://www.w3.org/ns/shacl#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix pulsefit:  <urn:pulsefit:ontology#> .

###############################################################################
# PulseFit Ontology SHACL 校验规则
###############################################################################

# ── 通用校验规则 ───────────────────────────────────────────────────────────
pulsefit:GenericShape
    a sh:NodeShape ;
    sh:property [
        sh:path pulsefit:hasName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "实体名称" ;
        sh:description "所有实体必须有且仅有一个名称"
    ] ;
    sh:property [
        sh:path pulsefit:hasDescription ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:name "实体描述" ;
        sh:description "所有实体必须有描述说明"
    ] .

# ── 人员校验规则 ───────────────────────────────────────────────────────────
pulsefit:PersonShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:Person ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:hasRole ;
        sh:class pulsefit:Role ;
        sh:minCount 1 ;
        sh:name "角色" ;
        sh:description "所有人员必须分配角色"
    ] ;
    sh:property [
        sh:path pulsefit:hasContact ;
        sh:class pulsefit:ContactInfo ;
        sh:minCount 1 ;
        sh:name "联系方式" ;
        sh:description "所有人员必须有联系方式"
    ] .

pulsefit:InfluencerShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:Influencer ;
    sh:node pulsefit:PersonShape ;
    sh:property [
        sh:path pulsefit:followerCount ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:minInclusive 0 ;
        sh:name "粉丝量" ;
        sh:description "网红必须填写粉丝量"
    ] ;
    sh:property [
        sh:path pulsefit:platform ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in ("Instagram" "TikTok" "YouTube" "Xiaohongshu" "Bilibili") ;
        sh:name "平台" ;
        sh:description "网红必须所属平台，且为指定平台列表"
    ] .

# ── 合同校验规则 ───────────────────────────────────────────────────────────
pulsefit:ContractShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:Contract ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:contractAmount ;
        sh:datatype xsd:float ;
        sh:minCount 1 ;
        sh:minExclusive 0 ;
        sh:name "合同金额" ;
        sh:description "合同必须有大于0的金额"
    ] ;
    sh:property [
        sh:path pulsefit:contractSignDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:name "签署日期" ;
        sh:description "合同必须有签署日期"
    ] ;
    sh:property [
        sh:path pulsefit:contractStatus ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in ("draft" "pending_approval" "signed" "executing" "completed" "expired" "terminated") ;
        sh:name "合同状态" ;
        sh:description "合同状态必须为指定值"
    ] ;
    sh:property [
        sh:path pulsefit:hasContractWith ;
        sh:class pulsefit:Influencer ;
        sh:minCount 1 ;
        sh:name "签约网红" ;
        sh:description "合同必须关联对应网红"
    ] ;
    sh:property [
        sh:path pulsefit:usesProduct ;
        sh:class pulsefit:Product ;
        sh:minCount 1 ;
        sh:name "合作产品" ;
        sh:description "合同必须关联合作产品"
    ] .

# ── 审批流校验规则 ─────────────────────────────────────────────────────────
pulsefit:ApprovalFlowShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:ApprovalFlow ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:approvalStatus ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in ("pending" "approved" "rejected" "cancelled") ;
        sh:name "审批状态" ;
        sh:description "审批状态必须为指定值"
    ] .

# ── 发货单校验规则 ─────────────────────────────────────────────────────────
pulsefit:ShipmentOrderShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:ShipmentOrder ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:shipmentStatus ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in ("pending" "preparing" "shipped" "in_transit" "delivered" "failed") ;
        sh:name "发货状态" ;
        sh:description "发货状态必须为指定值"
    ] ;
    sh:property [
        sh:path pulsefit:hasAddress ;
        sh:class pulsefit:Address ;
        sh:minCount 1 ;
        sh:name "收件地址" ;
        sh:description "发货单必须有收件地址"
    ] .

# ── 付款单校验规则 ─────────────────────────────────────────────────────────
pulsefit:PaymentOrderShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:PaymentOrder ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:paymentAmount ;
        sh:datatype xsd:float ;
        sh:minCount 1 ;
        sh:minExclusive 0 ;
        sh:name "付款金额" ;
        sh:description "付款金额必须大于0"
    ] ;
    sh:property [
        sh:path pulsefit:paymentStatus ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in ("pending" "processing" "paid" "failed" "cancelled") ;
        sh:name "付款状态" ;
        sh:description "付款状态必须为指定值"
    ] .

# ── 业务规则校验规则 ───────────────────────────────────────────────────────
pulsefit:BusinessRuleShape
    a sh:NodeShape ;
    sh:targetClass pulsefit:BusinessRule ;
    sh:node pulsefit:GenericShape ;
    sh:property [
        sh:path pulsefit:ruleCondition ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:name "规则触发条件" ;
        sh:description "所有业务规则必须明确触发条件"
    ] ;
    sh:property [
        sh:path pulsefit:ruleAction ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:name "规则执行动作" ;
        sh:description "所有业务规则必须明确执行动作"
    ] ;
    sh:property [
        sh:path pulsefit:rulePriority ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 10 ;
        sh:name "规则优先级" ;
        sh:description "规则优先级必须为1-10的整数，1最高"
    ] .
